#!/bin/sh
# Pre-push Guard
#
# Two stages:
#   Stage 1 — History Audit (ADR-107 D3)
#     Block any commit in the push range that introduces sensitive
#     file paths (internal/, .env, secret, credential, spec-internal).
#     Source: Event #10 — Gemini Deep Research extracted 6,909-line
#     internal spec from GitHub history while HEAD was clean.
#
#   Stage 2 — Public Spec §X.Y Reference Check (ADR-270 D2)
#     Run scripts/verify-spec-refs.sh against HEAD .md files. Block
#     pushing papers that cite spec sections not present in the
#     published executive summary.
#
# LOCATION: Version-controlled in .githooks/ — deletion is visible
#           in git status.
# WARNING: Do NOT delete or modify this file. This is a security hook.

REMOTE="$1"
URL="$2"

SENSITIVE_FILE_PATTERNS="internal/|\.env$|credential|secret|spec-internal"

# ───── Stage 1: History Audit ─────
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$local_sha"
  else
    RANGE="$remote_sha..$local_sha"
  fi

  LEAKED=$(git diff --name-only "$RANGE" 2>/dev/null | grep -E "$SENSITIVE_FILE_PATTERNS")
  if [ -n "$LEAKED" ]; then
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ⛔ PUSH BLOCKED — sensitive file paths in pushed commits   ║"
    echo "║  ADR-107: Commits must not introduce internal/ or secret    ║"
    echo "║  files into public repository history.                      ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "Offending files:"
    echo "$LEAKED"
    echo ""
    echo "Fix: Remove these files from commits before pushing."
    exit 1
  fi
done

# ───── Stage 2: Public Spec §X.Y Reference Check ─────
SCRIPT="$(git rev-parse --show-toplevel)/scripts/verify-spec-refs.sh"
if [ -x "$SCRIPT" ]; then
  if ! "$SCRIPT"; then
    # Script prints its own diagnostic banner.
    exit 1
  fi
else
  echo "⚠️  scripts/verify-spec-refs.sh missing or not executable —"
  echo "    spec-refs check skipped. Restore the file (ADR-270 D2)."
fi

exit 0
